{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Olimpo",
  "version": "1.3.0",
  "identifier": "com.jairo.olimpo",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Olimpo",
        "maximized": true,
        "decorations": false,
        "resizable": true,
        "minWidth": 1024,
        "minHeight": 640,
        "transparent": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data: asset: http://asset.localhost https://avatars.githubusercontent.com; font-src 'self' data:; connect-src 'self' ipc: http://ipc.localhost",
      "assetProtocol": {
        "enable": true,
        "scope": ["$APPDATA/wallpapers/*"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "nsis",
    "licenseFile": "../LICENSE",
    "windows": {
      "nsis": {
        "displayLanguageSelector": true,
        "languages": ["PortugueseBR", "English", "Spanish"],
        "installerIcon": "icons/icon.ico",
        "sidebarImage": "icons/nsis-sidebar.bmp",
        "headerImage": "icons/nsis-header.bmp",
        "installMode": "currentUser"
      }
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
